{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noEmit": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "paths": {
      "@actor-web/runtime": ["../actor-core-runtime/dist/index.d.ts"],
      "@actor-web/runtime/topology": ["../actor-core-runtime/dist/topology-entry.d.ts"],
      "@actor-web/runtime/event-sourcing": ["../actor-core-runtime/dist/event-sourcing-entry.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
