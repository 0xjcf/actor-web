{
  "name": "@actor-web/runtime",
  "version": "0.1.0",
  "description": "Core actor model runtime for universal actor-based applications",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/browser.ts src/topology-entry.ts src/node.ts --format cjs,esm && tsc --emitDeclarationOnly",
    "build:watch": "pnpm build --watch",
    "dev": "vitest --watch",
    "test": "vitest run",
    "test:unit": "vitest run src/unit",
    "test:integration": "vitest run src/integration --exclude '**/distributed-actor-directory.test.ts'",
    "test:all": "vitest run",
    "test:debug": "DEBUG_TESTS=true vitest run",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "actor-model",
    "state-machine",
    "message-passing",
    "reactive",
    "runtime"
  ],
  "author": "Actor-Core Team",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "xstate": "5.30.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./topology": {
      "types": "./dist/topology-entry.d.ts",
      "import": "./dist/topology-entry.js",
      "require": "./dist/topology-entry.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  }
}
