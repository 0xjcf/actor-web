{
  "fasRoot": "../FAS",
  "projectName": "actor-web",
  "projectType": "node",
  "branchPrefix": "codex/fas/",
  "runtimeImplementerCommand": "",
  "runtimeNotificationCommand": "",
  "runtimeGitHubEnabled": false,
  "runtimeAllowPush": false,
  "lintCommand": "pnpm lint",
  "formatCheckCommand": "pnpm exec biome format .",
  "formatFixCommand": "pnpm format",
  "typecheckCommand": "pnpm typecheck",
  "testCommand": "pnpm test && pnpm --filter @actor-web/runtime test",
  "replayCommand": "",
  "verifyScriptMode": "platform",
  "domainKnowledgeMapFile": "fas.domain-map.json",
  "screenshotArtifactDir": ".fas/artifacts/screenshots",
  "taskStateDir": ".fas/state",
  "queueFile": ".fas/queue/tasks.json",
  "boundaryPolicyFile": "",
  "architectureRulesFile": ".fas/architecture-rules.json",
  "behaviorBoundaryProfile": "throwing-adapters",
  "architectureProfile": "layered",
  "systemDocsDir": "docs",
  "behaviorBoundaries": {
    "functionalCore": [
      "packages/actor-core-runtime/src/type-helpers.ts",
      "packages/actor-core-runtime/src/utils/validation.ts"
    ],
    "shell": [
      "packages/actor-core-runtime/src/actor-instance.ts",
      "packages/actor-core-runtime/src/actor-system-impl.ts",
      "packages/actor-core-runtime/src/actor-system-guardian.ts",
      "packages/actor-core-runtime/src/actor-context-manager.ts",
      "packages/actor-core-runtime/src/actor-event-bus.ts",
      "packages/actor-core-runtime/src/actor-proxy.ts",
      "packages/actor-core-runtime/src/component-actor.ts",
      "packages/actor-core-runtime/src/create-actor.ts",
      "packages/actor-core-runtime/src/create-actor-ref.ts",
      "packages/actor-core-runtime/src/create-component.ts",
      "packages/actor-core-runtime/src/context-actor.ts",
      "packages/actor-core-runtime/src/stateless-actor.ts",
      "packages/actor-core-runtime/src/typed-actor-instance.ts",
      "packages/actor-core-runtime/src/unified-actor-builder.ts",
      "packages/actor-core-runtime/src/virtual-actor-system.ts",
      "packages/actor-core-runtime/src/actors/actor-discovery-service.ts",
      "packages/actor-core-runtime/src/actors/backoff-supervisor.ts",
      "packages/actor-core-runtime/src/actors/event-broker-actor.ts",
      "packages/actor-core-runtime/src/actors/supervisor.ts",
      "packages/actor-core-runtime/src/actors/supervisor-tree.ts",
      "packages/actor-core-runtime/src/actors/system-event-actor.ts",
      "packages/actor-core-runtime/src/planning/",
      "packages/actor-core-runtime/src/patterns/"
    ],
    "adapters": [
      "packages/actor-core-runtime/src/runtime/",
      "packages/actor-core-runtime/src/actors/scheduler-actor.ts",
      "packages/actor-core-runtime/src/actors/timer-actor.ts",
      "packages/actor-core-runtime/src/interceptors/",
      "packages/actor-core-runtime/src/messaging/",
      "packages/actor-core-runtime/src/memory/",
      "packages/actor-core-runtime/src/performance/",
      "packages/agent-workflow-cli/src/"
    ],
    "lifecycle": [],
    "scope": "all",
    "baseBranch": "main"
  },
  "monitorPacks": ["ci-regressions", "dependency-drift", "quality-checks"],
  "autonomyPolicy": {
    "mode": "independent-only",
    "runtimeMode": "active",
    "allowedTaskClasses": ["independent", "dependent", "monitor"],
    "maxActiveDraftPrs": 5,
    "maxStackDepth": 3,
    "forbiddenPaths": [],
    "forbiddenModules": [],
    "maxEstimatedToolCalls": null,
    "maxEstimatedApiCostUsd": null
  }
}
