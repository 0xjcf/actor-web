{
  "name": "actor-web",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for Actor-Web runtime, testing utilities, examples, and agent workflow tooling",
  "scripts": {
    "build": "pnpm --filter @actor-web/runtime build && pnpm --filter @actor-web/testing build && pnpm --filter @actor-web/agent build && pnpm --filter @actor-web/lattice build && pnpm --filter @actor-web/cli build",
    "build:watch": "pnpm --filter @actor-web/runtime build:watch",
    "dev": "vitest --watch",
    "test": "pnpm test:dom && pnpm test:runtime && pnpm test:lattice && pnpm test:examples",
    "test:dom": "vitest run --passWithNoTests",
    "test:cli": "pnpm --filter @actor-web/cli test",
    "test:runtime": "pnpm --filter @actor-web/runtime test",
    "test:lattice": "pnpm --filter @actor-web/lattice test",
    "test:examples": "vitest run --config examples/vitest.config.ts",
    "test:agent": "pnpm --filter @actor-web/agent test",
    "test:all": "pnpm test && pnpm test:agent && pnpm test:cli",
    "lint": "biome check . && pnpm lint:md",
    "lint:md": "markdownlint-cli2 --config .markdownlint.jsonc \".fas/TASKS.md\" \".fas/tasks/**/*.md\"",
    "lint:md:all": "markdownlint-cli2 --config .markdownlint.jsonc \"*.md\" \".github/**/*.md\" \".fas/TASKS.md\" \".fas/tasks/**/*.md\" \"docs/**/*.md\" \"examples/**/*.md\" \"packages/**/*.md\" \"tests/**/*.md\" \"#**/node_modules/**\" \"#**/dist/**\" \"#.pnpm-store/**\"",
    "architecture:check": "node scripts/check-architecture-boundaries.mjs",
    "format": "biome format . --write && pnpm format:md",
    "format:md": "markdownlint-cli2 --fix --config .markdownlint.jsonc \".fas/TASKS.md\" \".fas/tasks/**/*.md\"",
    "format:md:all": "markdownlint-cli2 --fix --config .markdownlint.jsonc \"*.md\" \".github/**/*.md\" \".fas/TASKS.md\" \".fas/tasks/**/*.md\" \"docs/**/*.md\" \"examples/**/*.md\" \"packages/**/*.md\" \"tests/**/*.md\" \"#**/node_modules/**\" \"#**/dist/**\" \"#.pnpm-store/**\"",
    "typecheck": "tsc --build",
    "clean": "pnpm --filter @actor-web/runtime clean && pnpm --filter @actor-web/testing clean && pnpm --filter @actor-web/agent clean && pnpm --filter @actor-web/lattice clean && pnpm --filter @actor-web/cli clean && rm -rf dist packages/*/*.tsbuildinfo",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:debug": "DEBUG_TESTS=true vitest run",
    "lint:fix": "biome check . --write && pnpm format:md",
    "format:imports": "biome check . --write --organize-imports-enabled=true",
    "format:all": "biome check . --write --organize-imports-enabled=true --formatter-enabled=true && pnpm format:md",
    "deps:check": "pnpm list tinypool && pnpm why tinypool",
    "deps:clean": "pnpm store prune && rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "examples:dev": "vite examples --config examples/vite.config.ts",
    "examples:dev:local": "vite examples --config examples/vite.config.ts --host 127.0.0.1 --port 4173",
    "examples:logistics": "vite-node --config examples/vite.config.ts scripts/dev-logistics-demo.ts",
    "examples:logistics:server": "vite-node --config examples/vite.config.ts examples/ignite-headless-host/logistics-server-process.ts",
    "examples:logistics:worker": "vite-node --config examples/vite.config.ts examples/ignite-headless-host/logistics-worker-process.ts",
    "examples:logistics:provider": "vite-node --config examples/vite.config.ts examples/ignite-headless-host/logistics-provider-process.ts",
    "examples:logistics:web": "vite examples --config examples/vite.config.ts --host 0.0.0.0 --port 4173",
    "examples:logistics:docker:start": "docker compose -f docker-compose.logistics.yml up --build -d",
    "examples:logistics:docker:start:provider": "ACTOR_WEB_PROVIDER_RUNTIME_ENABLED=1 ACTOR_WEB_PROVIDER_RUNTIME_SOURCE=container docker compose -f docker-compose.logistics.yml --profile provider-runtime up --build -d",
    "examples:logistics:docker:stop": "docker compose -f docker-compose.logistics.yml down --remove-orphans",
    "examples:logistics:docker:verify": "node scripts/verify-logistics-docker-compose.mjs",
    "examples:logistics:docker:verify:provider": "node scripts/verify-logistics-docker-compose.mjs --provider-runtime",
    "examples:build": "vite build examples --config examples/vite.config.ts",
    "docs:dev": "pnpm --filter docs-site dev",
    "docs:build": "pnpm --filter docs-site build",
    "docs:preview": "pnpm --filter docs-site preview",
    "docs:contrast": "pnpm --filter docs-site test:contrast",
    "docs:lint:md": "markdownlint-cli2 --config docs/site/.markdownlint.jsonc \"docs/site/**/*.md\" \"#**/node_modules/**\" \"#**/dist/**\"",
    "test:docs": "pnpm --filter docs-site build",
    "utils:date": "./scripts/date-utils.sh current",
    "utils:date-scan": "./scripts/date-utils.sh scan",
    "utils:date-fix": "./scripts/date-utils.sh fix-all",
    "utils:commit-config": "./scripts/commit-config.sh validate",
    "utils:commit-sample": "./scripts/commit-config.sh create-sample",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm release:stable",
    "release:prepare": "node scripts/release.mjs --channel stable --prepare-only",
    "release:stable": "node scripts/release.mjs --channel stable",
    "release:beta": "node scripts/release.mjs --channel beta"
  },
  "keywords": [
    "actor-model",
    "web-framework",
    "reactive",
    "state-management",
    "xstate",
    "observable",
    "typescript",
    "message-passing",
    "fault-tolerance",
    "supervision"
  ],
  "author": "0xjcf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xjcf/actor-web.git"
  },
  "bugs": {
    "url": "https://github.com/0xjcf/actor-web/issues"
  },
  "homepage": "https://github.com/0xjcf/actor-web#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.4",
    "@xstate/graph": "^3.0.4",
    "happy-dom": "^18.0.1",
    "ignite-element": "3.0.0-beta.8",
    "markdownlint-cli2": "^0.22.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "tinypool": "^1.1.1",
      "vitest": "^2.1.4"
    }
  }
}
